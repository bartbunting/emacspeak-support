#{{{clean

#preprocess element before sending it out:

proc clean {element} {
    global queue tts
    if {$tts(caps_beep)} {
        set element [native_capitalize_text $element]
    }
    if {[string match all $tts(punctuations)] } {
        regsub -all --  {\*} $element { `00 star } element
        regsub -all --  {-} $element { `00 dash } element
        regsub -all --  {;} $element { `00 semicolen } element
        regsub -all --  {\(} $element { `00 left `00 paren } element
        regsub -all --  {\)} $element { `00 right `00 paren } element
        regsub -all --  {@} $element { `00 at } element
        regsub -all --  {'} $element { apostrophe } element
        regsub -all -- {\$} $element { dollar } element; #
        regsub -all {[[:punct:]]} $element { \0 } element
    } else {
        regsub -all  {\yI'm\y} $element { I `00 am } element
        regsub -all  {[*&()\"]} $element  {}   element
        regsub -all { ?\-([[:digit:],]+\.[[:digit:]]+)} $element \
            { minus `p3 \1 } element
        regsub -all {([[:alpha:]])([[:punct:]])+([[:alnum:]])} $element \
            {\1 `p1 \3} element
        regsub -all {``} $element { `ar } element
        regsub -all {''} $element { `p3 } element
        regsub -all {' }  $element { `p1  } element
        regsub -all --  {--} $element { `p10  } element
        regsub -all -- {-}  $element {dash    } element
    }
    regsub -all {\240} $element " " element
    regsub -all {\y[A]\y} $element {[ey]} element
    set abbrev {\y[-_[:upper:]]{3,}\y}
    if {$tts(split_caps) } {
        while {[regexp $abbrev  $element match    ]}  {
            regsub $match $element "[string tolower $match]" element
        }
        regsub -all {[[:upper:]]} $element { &} element
        regsub -all {([^ -_[:upper:]])([[:upper:]][[:alpha:]]* )} $element\
            {\1 `p1 \2 } element
    }
    return $element
}

